# ─── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=devhub
POSTGRES_PORT=5432
# Connection string used by the API (devhub_app role)
DATABASE_URL=postgresql+asyncpg://devhub_app:devhub_app_password@localhost:5432/devhub

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ─── MCP servers ─────────────────────────────────────────────────────────────
# GitHub personal access token (needs repo, read:org scopes)
GITHUB_TOKEN=ghp_your_token_here
MCP_GITHUB_PORT=3001
MCP_GITHUB_URL=http://localhost:3001

# ─── LLM provider ────────────────────────────────────────────────────────────
# Choose provider: "anthropic" or "openai"
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-your_key_here
OPENAI_API_KEY=sk-your_key_here

# ─── LangSmith tracing (optional) ────────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls__your_key_here
LANGCHAIN_PROJECT=devhub-ai

# ─── Sentry ──────────────────────────────────────────────────────────────────
# Backend DSN (server-side only)
SENTRY_DSN=https://your_key@oXXXXXX.ingest.sentry.io/XXXXXXX
# Frontend DSN (exposed to browser via NEXT_PUBLIC_)
NEXT_PUBLIC_SENTRY_DSN=https://your_key@oXXXXXX.ingest.sentry.io/XXXXXXX
# Sentry org/project for source-map uploads (CI only)
SENTRY_ORG=your-org
SENTRY_PROJECT=devhub-web
SENTRY_AUTH_TOKEN=sntrys_your_token_here
# Set automatically in CI from git rev-parse HEAD
GIT_SHA=local
NEXT_PUBLIC_GIT_SHA=local

# ─── OpenTelemetry (optional) ────────────────────────────────────────────────
# Set to enable OTLP trace export (e.g. http://localhost:4318 for local Tempo)
OTEL_EXPORTER_OTLP_ENDPOINT=

# ─── App ─────────────────────────────────────────────────────────────────────
# Environment: development | production
APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=change_me_in_production_use_openssl_rand_hex_32
